<Window x:Class="FileScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileScanner"
        mc:Ignorable="d"
        Icon="Assets/Icons/folder-scanner.ico"
        Title="File Scanner" 
        Height="510" 
        Width="900">

    <!-- Define local styles for consistent buttons appearance and behavior across the application -->
    <!-- Override the default styles and behaviors -->
    <Window.Resources>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="MinHeight" Value="34" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="#1F3A5F"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#162A44" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#0F1F33" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#B0BEC5" />
                                <Setter Property="Foreground"
                                        Value="#ECEFF1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SECONDARY BUTTON -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="32" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                     Background="#EEF1F5"
                     BorderBrush="#D0D5DD"
                     BorderThickness="1"
                     CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                             Property="Background"
                             Value="#E2E6EA" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                             Property="Background"
                             Value="#DCE1E6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="MinHeight" Value="32" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                     Background="#B42318"
                     CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                             Property="Background"
                             Value="#8F1A14" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                             Property="Background"
                             Value="#721611" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Folder row-->
            <RowDefinition Height="Auto" />  <!-- Date + radio row-->
            <RowDefinition Height="Auto" />  <!-- Start/Export Buttons row-->
            <RowDefinition Height="Auto" />  <!-- Progress status -->
            <RowDefinition Height="*" />     <!-- Results -->
        </Grid.RowDefinitions>
        
        <!-- ==================== -->
        <!-- Folder selection row -->
        <!-- ==================== -->
        <StackPanel x:Name="UIFilterSection">
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="450" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label Content="Folder:"
                   Grid.Column="0"
                   Width="55"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0" />

            <TextBox x:Name="FolderTextBox"
                     Grid.Column="1"
                     TextChanged="FilterChanged"
                     VerticalAlignment="Center"
                     IsReadOnly="True" 
                     MinHeight="28"
                     Background="#F2F4F7"
                     BorderBrush="#B8C1CC" 
                     VerticalContentAlignment="Center" />

            <Button Content="Browse..."
                    Grid.Column="2"
                    Width="100"
                    Click="BrowseButton_Click"
                    Margin="0,0,20,0" 
                    MinHeight="28"
                    Style="{StaticResource SecondaryButton}" />

            <CheckBox x:Name="IncludeHiddenFilesCheckBox"
                      Grid.Column="3"
                      Content="Hidden"
                      Checked="FilterChanged"
                      Unchecked="FilterChanged"
                      VerticalAlignment="Center"
                      Margin="0,0,15,0">
                      
                <CheckBox.ToolTip>
                    <TextBlock>
                        Tick this box to include hidden files.
                        <LineBreak />
                        Note: Some files may have mutiple attributes at the same time (e.g. Hidden and System).
                        <LineBreak />
                        Select all applicable options to include them.
                    </TextBlock>
                </CheckBox.ToolTip>
            </CheckBox>

            <CheckBox x:Name="IncludeSystemFilesCheckBox"
                      Grid.Column="4"
                      Content="System"     
                      Checked="FilterChanged"
                      Unchecked="FilterChanged"
                      VerticalAlignment="Center">

                <CheckBox.ToolTip>
                    <TextBlock>
                            Tick this box to include protected system files.
                            <LineBreak />
                            Note: Some files may have mutiple attributes at the same time (e.g. Hidden and System).
                            <LineBreak />
                            Select all applicable options to include them.
                    </TextBlock>
                </CheckBox.ToolTip>
            </CheckBox>
        </Grid>
        
        <!-- ============ -->
        <!-- Date + radio -->
        <!-- ============ -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center"
                    Margin="0,10,0,10">

            <Label Content="Date"
                   Width="55"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0" />

            <DatePicker x:Name="DatePickerControl" 
                        SelectedDateChanged="FilterChanged"
                        Width="150"
                        Margin="0,0,15,0" 
                        VerticalAlignment="Center" />

            <RadioButton x:Name="BeforeRadio"
                         Content="Before"
                         Checked="FilterChanged"
                         ToolTip="Show files modified before the selected date"
                         IsChecked="True"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0" />

            <RadioButton x:Name="AfterRadio"
                         Content="After"
                         Checked="FilterChanged"
                         ToolTip="Show files modified after the selected date"
                         VerticalAlignment="Center" />
        </StackPanel>

        </StackPanel>



        <!-- =================================== -->
        <!-- Start Scan & Export Results buttons -->
        <!-- =================================== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,5,0,5">
            

            <Button x:Name="DeleteButton"
                    Content="Delete All"
                    Width="120"
                    Height="30"
                    Margin="5"
                    Visibility="Visible"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    FontWeight="Medium" 
                    Background="#FFFF6767" 
                    Click="DeleteButton_Click" 
                    Style="{StaticResource DangerButton}" />

            
            <Button x:Name="StopButton"
                    Style="{StaticResource SecondaryButton}"
                    Click="StopButton_Click"
                    Content="Stop Scan"
                    HorizontalAlignment="Center"
                    Width="115"
                    Height="30"
                    Margin="5"
                    Visibility="Hidden"
                    VerticalAlignment="Center" 
                    FontWeight="Medium" />

            <Button x:Name="StartButton"
                    Style="{StaticResource PrimaryButton}"
                    Content="Start Scan"
                    Click="StartButton_Click"
                    Margin="5"
                    Width="115"
                    Height="30"
                    Background="#FF99C2E2" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    FontWeight="Bold" />

            <Button x:Name="ExportButton"
                    Content="Export Results"
                    Click="ExportButton_Click"
                    HorizontalAlignment="Center"
                    Width="115"
                    Height="30"
                    Margin="5"
                    Visibility="Hidden" 
                    VerticalAlignment="Center"
                    FontWeight="Medium" 
                    Style="{StaticResource SecondaryButton}" />
            
        </StackPanel>

        <ProgressBar x:Name="ScanProgressBar"
                     Grid.Row="3"
                     Height="6"
                     Margin="0,8,0,0"
                     IsIndeterminate="True"
                     Visibility="Hidden" />

        <!-- ======= -->     
        <!-- Results -->
        <!-- ======= -->
        <DataGrid Grid.Row="4"
                  x:Name="ResultsDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="File Path"
                                    Binding="{Binding FilePath}"
                                    Width="*" />
                <DataGridTextColumn Header="Last Modified"
                                    Binding="{Binding LastModified, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="200" />
                <DataGridTextColumn Header="Owner"
                                    Binding="{Binding Owner}"
                                    Width="200" />
            </DataGrid.Columns>
        </DataGrid>
    

    </Grid>
</Window>
